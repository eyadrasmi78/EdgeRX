APP_NAME=EdgeRX
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
FRONTEND_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Postgres (docker-compose service "postgres") ---
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=edgerx
DB_USERNAME=edgerx
DB_PASSWORD=edgerx

# --- Sessions / Cache / Queue ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

CACHE_STORE=redis
CACHE_PREFIX=edgerx_
QUEUE_CONNECTION=redis

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Sanctum SPA auth ---
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:80,localhost:3000,127.0.0.1,127.0.0.1:80,edgerx.app,www.edgerx.app

# --- Mail (Mailpit local; SendGrid in prod) ---
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@edgerx.app
MAIL_FROM_NAME="EdgeRX"

# Production override (set in DO App Platform env vars):
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=<SENDGRID_API_KEY>
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=noreply@em.edgerx.app

# --- Filesystem (local dev; spaces in prod) ---
FILESYSTEM_DISK=local

# Production override:
# FILESYSTEM_DISK=spaces
# DO_SPACES_KEY=
# DO_SPACES_SECRET=
# DO_SPACES_REGION=fra1
# DO_SPACES_BUCKET=edgerx-uploads
# DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com

# --- Broadcasting (kept "log" for 4h-demo scope; switch to "reverb" post-demo) ---
BROADCAST_CONNECTION=log

# --- AI (server-side Gemini proxy) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,https://edgerx.app,https://www.edgerx.app

VITE_APP_NAME="${APP_NAME}"
